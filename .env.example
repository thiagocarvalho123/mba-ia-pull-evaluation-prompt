# LangSmith - obrigatório
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=prompt-optimization-challenge-resolved

# LangSmith Hub - seu username para publicar prompts
USERNAME_LANGSMITH_HUB=seu_username

# Provider de LLM: "google" ou "openai"
LLM_PROVIDER=google

# Google Gemini (gratuito)
GOOGLE_API_KEY=AIza...
LLM_MODEL=gemini-2.5-flash
EVAL_MODEL=gemini-2.5-flash

# OpenAI (alternativa paga)
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# EVAL_MODEL=gpt-4o
